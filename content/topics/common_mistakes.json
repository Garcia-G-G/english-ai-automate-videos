[
  {"id": "cm001", "wrong": "I have 25 years", "correct": "I am 25 years old", "explanation": "En inglés ERES tu edad, no la TIENES", "difficulty": "beginner", "tags": ["very_common", "ser_estar"]},
  {"id": "cm002", "wrong": "I am agree", "correct": "I agree", "explanation": "Agree es verbo, no necesita am", "difficulty": "beginner", "tags": ["very_common", "verbs"]},
  {"id": "cm003", "wrong": "People is", "correct": "People are", "explanation": "People es plural en inglés", "difficulty": "beginner", "tags": ["very_common", "subject_verb"]},
  {"id": "cm004", "wrong": "I am boring", "correct": "I am bored", "explanation": "-ED para sentir, -ING para causar", "difficulty": "beginner", "tags": ["very_common", "adjectives"]},
  {"id": "cm005", "wrong": "Make a party", "correct": "Have/throw a party", "explanation": "Se usa throw a party o have a party", "difficulty": "beginner", "tags": ["very_common", "collocations"]},
  {"id": "cm006", "wrong": "Do a mistake", "correct": "Make a mistake", "explanation": "Make con: mistakes, decisions, money", "difficulty": "beginner", "tags": ["very_common", "make_do"]},
  {"id": "cm007", "wrong": "Say me", "correct": "Tell me", "explanation": "Tell + persona, Say + palabras", "difficulty": "beginner", "tags": ["very_common", "say_tell"]},
  {"id": "cm008", "wrong": "Explain me", "correct": "Explain to me", "explanation": "Explain TO someone", "difficulty": "beginner", "tags": ["very_common", "prepositions"]},
  {"id": "cm009", "wrong": "Depend of", "correct": "Depend on", "explanation": "Depend ON something", "difficulty": "beginner", "tags": ["very_common", "prepositions"]},
  {"id": "cm010", "wrong": "Listen music", "correct": "Listen to music", "explanation": "Listen TO something", "difficulty": "beginner", "tags": ["very_common", "prepositions"]},
  {"id": "cm011", "wrong": "I'm interesting in art", "correct": "I'm interested in art", "explanation": "-ED = cómo te sientes, -ING = lo que causa el sentimiento", "difficulty": "beginner", "tags": ["very_common", "adjectives"]},
  {"id": "cm012", "wrong": "She said me to go", "correct": "She told me to go", "explanation": "Tell + persona + to do. Say no lleva persona directa", "difficulty": "beginner", "tags": ["very_common", "say_tell"]},
  {"id": "cm013", "wrong": "I go to home", "correct": "I go home", "explanation": "Home no necesita preposición: go home, come home, get home", "difficulty": "beginner", "tags": ["very_common", "prepositions"]},
  {"id": "cm014", "wrong": "He doesn't can swim", "correct": "He can't swim", "explanation": "Los modales (can, must, should) no usan does/doesn't", "difficulty": "beginner", "tags": ["very_common", "modals"]},
  {"id": "cm015", "wrong": "I am agree with you", "correct": "I agree with you", "explanation": "Agree ya es verbo. No necesita 'am'", "difficulty": "beginner", "tags": ["very_common", "verbs"]},
  {"id": "cm016", "wrong": "She is married with him", "correct": "She is married to him", "explanation": "Married TO someone, no married with", "difficulty": "intermediate", "tags": ["common", "prepositions"]},
  {"id": "cm017", "wrong": "I went to there", "correct": "I went there", "explanation": "There, here, home = no preposición con go/come", "difficulty": "beginner", "tags": ["common", "prepositions"]},
  {"id": "cm018", "wrong": "He said me the truth", "correct": "He told me the truth", "explanation": "Tell me, tell you, tell him. Say the truth (sin persona)", "difficulty": "beginner", "tags": ["very_common", "say_tell"]},
  {"id": "cm019", "wrong": "I must to go", "correct": "I must go", "explanation": "Después de modales (must, can, should, will) va verbo sin TO", "difficulty": "beginner", "tags": ["very_common", "modals"]},
  {"id": "cm020", "wrong": "I am not agree", "correct": "I don't agree / I disagree", "explanation": "Agree usa do/does para negativo, no am/is/are", "difficulty": "beginner", "tags": ["very_common", "verbs"]},
  {"id": "cm021", "wrong": "Is raining", "correct": "It is raining", "explanation": "En inglés siempre se necesita sujeto. El clima usa IT", "difficulty": "beginner", "tags": ["very_common", "subject"]},
  {"id": "cm022", "wrong": "I have hungry", "correct": "I am hungry", "explanation": "En inglés ERES hambriento, no TIENES hambre", "difficulty": "beginner", "tags": ["very_common", "ser_estar"]},
  {"id": "cm023", "wrong": "I have cold", "correct": "I am cold", "explanation": "En inglés ERES frío (sientes frío), no TIENES frío", "difficulty": "beginner", "tags": ["very_common", "ser_estar"]},
  {"id": "cm024", "wrong": "The life is beautiful", "correct": "Life is beautiful", "explanation": "No uses THE con conceptos generales: life, love, time, music", "difficulty": "intermediate", "tags": ["common", "articles"]},
  {"id": "cm025", "wrong": "I like go to the beach", "correct": "I like going to the beach / I like to go to the beach", "explanation": "Like + gerund (-ing) o like + to + infinitive", "difficulty": "beginner", "tags": ["common", "gerund_infinitive"]},
  {"id": "cm026", "wrong": "She is more taller", "correct": "She is taller", "explanation": "No uses more + -er. Es more beautiful O taller, no los dos", "difficulty": "beginner", "tags": ["common", "comparatives"]},
  {"id": "cm027", "wrong": "I didn't went", "correct": "I didn't go", "explanation": "Después de did/didn't el verbo va en forma base, no pasado", "difficulty": "beginner", "tags": ["very_common", "past_tense"]},
  {"id": "cm028", "wrong": "Informations", "correct": "Information", "explanation": "Information es incontable. No tiene plural. Usa 'pieces of information'", "difficulty": "intermediate", "tags": ["common", "uncountable"]},
  {"id": "cm029", "wrong": "Advices", "correct": "Advice", "explanation": "Advice es incontable. Usa 'a piece of advice' o 'some advice'", "difficulty": "intermediate", "tags": ["common", "uncountable"]},
  {"id": "cm030", "wrong": "I am used to go there", "correct": "I used to go there", "explanation": "Used to (pasado) vs am used to (acostumbrado a). Sin 'am' = hábito del pasado", "difficulty": "intermediate", "tags": ["common", "used_to"]},
  {"id": "cm031", "wrong": "He suggested me to go", "correct": "He suggested that I go / He suggested going", "explanation": "Suggest no usa persona + to. Usa suggest + -ing o suggest + that", "difficulty": "intermediate", "tags": ["common", "verbs"]},
  {"id": "cm032", "wrong": "I enjoy to swim", "correct": "I enjoy swimming", "explanation": "Enjoy siempre va con -ing, nunca con to", "difficulty": "intermediate", "tags": ["common", "gerund_infinitive"]},
  {"id": "cm033", "wrong": "Where I can find it?", "correct": "Where can I find it?", "explanation": "En preguntas: Where + auxiliar + sujeto + verbo", "difficulty": "beginner", "tags": ["common", "word_order"]},
  {"id": "cm034", "wrong": "I have been to Paris last year", "correct": "I went to Paris last year", "explanation": "Con tiempo específico (last year) usa Past Simple, no Present Perfect", "difficulty": "intermediate", "tags": ["common", "tenses"]},
  {"id": "cm035", "wrong": "He always is late", "correct": "He is always late", "explanation": "Adverbios de frecuencia van ANTES del verbo, pero DESPUÉS de be", "difficulty": "intermediate", "tags": ["common", "word_order"]}
]
