  "segments": [
    {
      "lang": "spanish",
      "text": "¿Sabías que"
    },
    {
      "lang": "english",
      "text": "embarrassed"
    },
    {
      "lang": "spanish",
      "text": "NO significa embarazada?\nMuchos hispanohablantes cometen este error.\nEn inglés,"
    },
    {
      "lang": "english",
      "text": "embarrassed"
    },
    {
      "lang": "spanish",
      "text": "significa sentirse avergonzado o incómodo.\nPor ejemplo:"
    },
    {
      "lang": "english",
      "text": "I was so embarrassed when I forgot her name"
    },
    {
      "lang": "spanish",
      "text": ".\nSi quieres decir embarazada en inglés, la palabra correcta es"
    },
    {
      "lang": "english",
      "text": "pregnant"
    },
    {
      "lang": "spanish",
      "text": ".\nRecuerda:"
    },
    {
      "lang": "english",
      "text": "embarrassed"
    },
    {
      "lang": "spanish",
      "text": "tiene doble R, ¡como cuando tu cara se pone ROJA de vergüenza!\n¿Conocías este falso amigo? ¡Cuéntame en los comentarios!"
    }
  ]
}