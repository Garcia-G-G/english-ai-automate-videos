# ============================================
# English AI Videos - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
# ============================================

# ── REQUIRED ──────────────────────────────────
# OpenAI API Key (for GPT script generation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxx

# ── TTS CONFIGURATION ────────────────────────
# Provider: elevenlabs (best quality), openai, google, edge (free)
TTS_PROVIDER=elevenlabs

# ElevenLabs TTS (recommended for quality)
# Get yours at: https://elevenlabs.io/api
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=ZOgeDYxfyev5qgOXq2lN

# OpenAI TTS (alternative)
# TTS_SPEED=0.9

# Google Cloud TTS (alternative)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── SOCIAL MEDIA UPLOADS ─────────────────────
# TikTok Content Posting API
# Register at: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube Data API v3
# Create credentials at: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Instagram Graph API (via Facebook Business)
# Setup at: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
